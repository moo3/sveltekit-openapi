{
  "name": "@sveltekit-openapi/core",
  "version": "0.1.0",
  "description": "Auto-generate OpenAPI 3.1 docs from SvelteKit API routes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sveltekit-openapi": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "sveltekit",
    "openapi",
    "swagger",
    "api",
    "documentation",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ts-morph": "^25.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.5.2",
    "semantic-release": "^25.0.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
